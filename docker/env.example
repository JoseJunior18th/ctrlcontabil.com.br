# Frontend
NODE_ENV=production
PORT=8232
API_BASE_URL=https://ctrlcontabil.josejunior.eng.br
NEXT_PUBLIC_API_BASE_URL=https://ctrlcontabil.josejunior.eng.br
API_INTERNAL_BASE_URL=http://api:5075
FRONTEND_BASE_URL=https://ctrlcontabil.josejunior.eng.br
SESSION_COOKIE_NAME=__Host-ctrl_session


# Backend
ENVIRONMENT=production
API_BASE_URL=https://ctrlcontabil.josejunior.eng.br
FRONTEND_BASE_URL=https://ctrlcontabil.josejunior.eng.br
AUTHENTIK_ISSUER=https://authentik.onneonline.com.br/application/o/ctrlcontabil/
AUTHENTIK_CLIENT_ID=replace-with-authentik-client-id
AUTHENTIK_CLIENT_SECRET=replace-with-authentik-client-secret
AUTHENTIK_ALGORITHMS=RS256


# Optional SAML fallback, only if the deployment uses Authentik SAML instead of OIDC.
# SAML_IDP_ENTITY_ID=https://authentik.onneonline.com.br/application/saml/ctrlcontabil/metadata/
# SAML_IDP_SSO_URL=https://authentik.onneonline.com.br/application/saml/ctrlcontabil/sso/binding/redirect/
# SAML_IDP_SLO_URL=https://authentik.onneonline.com.br/application/saml/ctrlcontabil/slo/binding/redirect/
# SAML_IDP_X509_CERT=-----BEGIN CERTIFICATE-----...
# SAML_SP_X509_CERT=-----BEGIN CERTIFICATE-----...
# SAML_SP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----...


SESSION_SECRET=replace-with-at-least-32-random-bytes
SESSION_COOKIE_NAME=__Host-ctrl_session
SECURE_COOKIES=true
ENABLE_HTTPS_REDIRECT=true
ALLOWED_ORIGINS=https://ctrlcontabil.josejunior.eng.br
ALLOWED_RETURN_HOSTS=ctrlcontabil.josejunior.eng.br
TRUSTED_HOSTS=ctrlcontabil.josejunior.eng.br,localhost,127.0.0.1,api
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
